        "sharepointLists": [ "wmreply_Replybrary_Project_List" ],
        "connectors": [ "shared_sharepointonline", "shared_teams" ]
      }
    },
    {
      "name": "Replybrary | Daily Pipedrive check",
      "uses": { "connectors": [ "shared_sharepointonline" ] }
    },
    {
      "name": "PMflow",
      "uses": {
        "sharepointLists": [ "Replybrary_Project_List" ],
        "connectors": [ "shared_sharepointonline", "shared_teams" ]
      }
    },
    {
      "name": "UploadLogo",
